{
  "name": "esimapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "// Sitemap Scripts": "// ===========================", 
    "sitemap": "next-sitemap --config next-sitemap.config.js",
    "sitemap:dev": "next-sitemap --config next-sitemap.config.js",
    "sitemap:test": "node scripts/test-sitemap-dev.js",
    "sitemap:analyze": "node scripts/test-sitemap-dev.js",
    "sitemap:urls": "node scripts/test-sitemap-dev.js --test-urls",
    "sitemap:clean": "rm -f public/sitemap*.xml public/robots.txt",
    "sitemap:discover": "node scripts/discover-pages.js",
    "// Development Scripts": "// ===========================",
    "dev:full": "npm run sitemap:clean && npm run dev",
    "test:apis": "curl http://localhost:3000/api/blogs && curl http://localhost:3000/api/esim/locations",
    "validate:sitemap": "xmllint --noout public/sitemap.xml || echo 'XML validation failed or xmllint not installed'",
    "// Production Scripts": "// ===========================",
    "build:full": "npm run sitemap:clean && npm run build",
    "deploy:prepare": "npm run build:full && npm run validate:sitemap",
    "validate:production": "node scripts/validate-production.js",
    "validate:domain": "node scripts/validate-production.js",
    "gsc:help": "node scripts/validate-production.js --verification"
  },
  "dependencies": {
    "@next-auth/mongodb-adapter": "^1.1.3",
    "@stripe/react-stripe-js": "^3.6.0",
    "@stripe/stripe-js": "^7.1.0",
    "@tiptap/extension-character-count": "^2.11.7",
    "@tiptap/extension-image": "^2.11.7",
    "@tiptap/extension-link": "^2.11.7",
    "@tiptap/extension-placeholder": "^2.11.7",
    "@tiptap/extension-text-align": "^2.11.7",
    "@tiptap/extension-underline": "^2.11.7",
    "@tiptap/extension-youtube": "^2.11.7",
    "@tiptap/react": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "axios": "^1.8.4",
    "cloudinary": "^2.6.0",
    "country-flags-svg": "^2.0.0-beta.1",
    "date-fns": "^4.1.0",
    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0",
    "lucide-react": "^0.487.0",
    "mongoose": "^8.13.2",
    "next": "15.2.6",
    "next-auth": "^4.24.11",
    "next-sitemap": "^4.2.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-round-flags": "^1.0.5",
    "react-world-flags": "^1.6.0",
    "sanitize-html": "^2.16.0",
    "stripe": "^18.0.0",
    "svg-country-flags": "^1.2.10",
    "sweetalert2": "^11.22.1",
    "swiper": "^11.2.6",
    "swr": "^2.3.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "tailwindcss": "^4.1.3"
  }
}
